@page "/"
@using Models
@inject NavigationManager NavigationManager
@inject ToDoDb ToDoDb

<PageTitle>To Do List</PageTitle>

<h1>To Do List</h1>

@if (toDos is null)
{
    <h3><em>Loading...</em></h3>
}
else
{
    <DeleteToDo ToDo="popUpToDo" Close="DeleteModal"></DeleteToDo>
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>To Do Name</th>
                <th>Type</th>
                <th>Priority (0-10)</th>
                <th>Date Due</th>
                <th>Edit/Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var toDo in toDos)
            {
                <tr>
                    <td>@toDo.Name</td>
                    <td>@toDo.Type</td>
                    <td>@toDo.Priority</td>
                    <td>@toDo.DueDate.ToString("MM/dd/yyyy")</td>
                    <td><button class="btn btn-primary" @onclick="(() => EditToDo(toDo.Id))">Edit</button>
                        <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal"
                            @onclick="(() => popUpToDo = toDo)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="row mb-4">
        <div class="col-sm-6">
            <button type="button" class="btn btn-primary" @onclick="CreateToDo">New To Do Item</button>
        </div>
    </div>
}

@code {
    private ToDo[]? toDos;
    private ToDo? popUpToDo;
    protected override async Task OnInitializedAsync()
    {
        await ToDoDb.LoadToDoDataAsync();
        toDos = ToDoDb.GetToDos();
    }
    private void CreateToDo()
    {
        NavigationManager.NavigateTo("/edit");
    }
    private void EditToDo(int id)
    {
        NavigationManager.NavigateTo($"/edit/{id}");
    }
    private void DeleteModal(bool accepted)
    {
        if (accepted)
        {
            ToDoDb.DeleteToDo(popUpToDo!.Id);
            toDos = ToDoDb.GetToDos();
        }
    }
    public ToDo[] GetTo() => toDos;
}